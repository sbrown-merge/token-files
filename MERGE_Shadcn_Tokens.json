          "foreground": { "$type": "color", "$value": "{Semantic.light.destructive.foreground}" }
        },
        "outline": {
          "border": { "$type": "color", "$value": "{Semantic.light.input}" }
        }
      }
    },
    "dark": {
      "button": {
        "primary": {
          "background": {
            "default": { "$type": "color", "$value": "{Semantic.dark.primary.DEFAULT}" },
            "hover": { "$type": "color", "$value": "{Primitives.color.brand.electrolight.400}" }
