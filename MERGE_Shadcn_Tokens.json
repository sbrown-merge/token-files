  "Component": {
    "light": {
      "button": {
        "primary": {
          "background": {
            "default": { "$type": "color", "$value": "{Semantic.light.primary.DEFAULT}" },
            "hover": { "$type": "color", "$value": "{Primitives.color.brand.viridian.600}" }
          },
          "foreground": { "$type": "color", "$value": "{Semantic.light.primary.foreground}" }
        },
        "secondary": {
