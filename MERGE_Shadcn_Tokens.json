            "default": { "$type": "color", "$value": "{Semantic.light.secondary.DEFAULT}" },
            "hover": { "$type": "color", "$value": "{Primitives.color.brand.darkGreen.700}" }
          },
          "foreground": { "$type": "color", "$value": "{Semantic.light.secondary.foreground}" }
