{
  "Primitives": {
    "color": {
      "white": { "$value": "#ffffff", "$type": "color" },
      "black": { "$value": "#000000", "$type": "color" },
      "slate": {
        "50": { "$value": "#f8fafc", "$type": "color" },
        "100": { "$value": "#f1f5f9", "$type": "color" },
        "200": { "$value": "#e2e8f0", "$type": "color" },
        "300": { "$value": "#cbd5e1", "$type": "color" },
        "400": { "$value": "#94a3b8", "$type": "color" },
        "500": { "$value": "#64748b", "$type": "color" },
        "600": { "$value": "#475569", "$type": "color" },
        "700": { "$value": "#334155", "$type": "color" },
        "800": { "$value": "#1e293b", "$type": "color" },
        "900": { "$value": "#0f172a", "$type": "color" },
        "950": { "$value": "#020617", "$type": "color" }
      },
      "red": {
        "50": { "$value": "#fef2f2", "$type": "color" },
        "500": { "$value": "#ef4444", "$type": "color" },
        "900": { "$value": "#7f1d1d", "$type": "color" }
      }
    },
    "spacing": {
      "0": { "$value": "0px", "$type": "dimension" },
      "1": { "$value": "4px", "$type": "dimension" },
      "2": { "$value": "8px", "$type": "dimension" },
      "3": { "$value": "12px", "$type": "dimension" },
      "4": { "$value": "16px", "$type": "dimension" },
      "6": { "$value": "24px", "$type": "dimension" },
      "8": { "$value": "32px", "$type": "dimension" },
      "12": { "$value": "48px", "$type": "dimension" }
    },
    "radius": {
      "none": { "$value": "0px", "$type": "dimension" },
      "sm": { "$value": "4px", "$type": "dimension" },
      "md": { "$value": "6px", "$type": "dimension" },
      "lg": { "$value": "8px", "$type": "dimension" },
      "full": { "$value": "9999px", "$type": "dimension" }
    },
    "typography": {
      "fontFamily": {
        "sans": { "$value": "Inter", "$type": "fontFamily" }
      },
      "fontSize": {
        "xs": { "$value": "14px", "$type": "dimension", "$description": "Small text, captions" },
        "sm": { "$value": "16px", "$type": "dimension", "$description": "Secondary text, metadata" },
        "base": { "$value": "18px", "$type": "dimension", "$description": "Primary body text" },
        "lg": { "$value": "20px", "$type": "dimension", "$description": "Large body, prominent UI elements" },
        "xl": { "$value": "24px", "$type": "dimension", "$description": "Small headings (h4/h5)" },
        "2xl": { "$value": "30px", "$type": "dimension", "$description": "Medium headings (h3)" },
        "3xl": { "$value": "36px", "$type": "dimension", "$description": "Large headings (h2)" },
        "4xl": { "$value": "48px", "$type": "dimension", "$description": "Display headings (h1)" },
        "5xl": { "$value": "60px", "$type": "dimension", "$description": "Hero display sizes" }
      },
      "fontWeight": {
        "normal": { "$value": "400", "$type": "fontWeight" },
        "medium": { "$value": "500", "$type": "fontWeight" },
        "semibold": { "$value": "600", "$type": "fontWeight" },
        "bold": { "$value": "700", "$type": "fontWeight" }
      },
      "lineHeight": {
        "none": { "$value": "1", "$type": "number" },
        "tight": { "$value": "1.25", "$type": "number" },
        "snug": { "$value": "1.375", "$type": "number" },
        "normal": { "$value": "1.5", "$type": "number", "$description": "Standard body line-height" },
        "relaxed": { "$value": "1.625", "$type": "number" }
      }
    }
  },
  "Semantic": {
    "theme": {
      "background": {
        "$type": "color",
        "$value": {
          "light": "{Primitives.color.white}",
          "dark": "{Primitives.color.slate.950}"
        }
      },
      "foreground": {
        "$type": "color",
        "$value": {
          "light": "{Primitives.color.slate.950}",
          "dark": "{Primitives.color.slate.50}"
        }
      },
      "card": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.white}",
            "dark": "{Primitives.color.slate.950}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.950}",
            "dark": "{Primitives.color.slate.50}"
          }
        }
      },
      "popover": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.white}",
            "dark": "{Primitives.color.slate.950}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.950}",
            "dark": "{Primitives.color.slate.50}"
          }
        }
      },
      "primary": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.900}",
            "dark": "{Primitives.color.slate.50}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.50}",
            "dark": "{Primitives.color.slate.900}"
          }
        }
      },
      "secondary": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.100}",
            "dark": "{Primitives.color.slate.800}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.900}",
            "dark": "{Primitives.color.slate.50}"
          }
        }
      },
      "muted": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.100}",
            "dark": "{Primitives.color.slate.800}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.500}",
            "dark": "{Primitives.color.slate.400}"
          }
        }
      },
      "accent": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.100}",
            "dark": "{Primitives.color.slate.800}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.900}",
            "dark": "{Primitives.color.slate.50}"
          }
        }
      },
      "destructive": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.red.500}",
            "dark": "{Primitives.color.red.900}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.50}",
            "dark": "{Primitives.color.slate.50}"
          }
        }
      },
      "border": {
        "$type": "color",
        "$value": {
          "light": "{Primitives.color.slate.200}",
          "dark": "{Primitives.color.slate.800}"
        }
      },
      "input": {
        "$type": "color",
        "$value": {
          "light": "{Primitives.color.slate.200}",
          "dark": "{Primitives.color.slate.800}"
        }
      },
      "ring": {
        "$type": "color",
        "$value": {
          "light": "{Primitives.color.slate.950}",
          "dark": "{Primitives.color.slate.300}"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "{Primitives.radius.md}",
        "$description": "Radius applies globally to both light and dark modes"
      }
    }
  },
  "Component": {
    "button": {
      "primary": {
        "background": {
          "default": { "$type": "color", "$value": "{Semantic.theme.primary.DEFAULT}" },
          "hover": { 
            "$type": "color", 
            "$value": {
              "light": "{Primitives.color.slate.800}",
              "dark": "{Primitives.color.slate.200}"
            },
            "$description": "Solid primitive fallback for Shadcn's primary/90 hover"
          }
        },
        "foreground": { "$type": "color", "$value": "{Semantic.theme.primary.foreground}" }
      },
      "secondary": {
        "background": {
          "default": { "$type": "color", "$value": "{Semantic.theme.secondary.DEFAULT}" },
          "hover": { 
            "$type": "color", 
            "$value": {
              "light": "{Primitives.color.slate.200}",
              "dark": "{Primitives.color.slate.700}"
            },
            "$description": "Solid primitive fallback for Shadcn's secondary/80 hover"
          }
        },
        "foreground": { "$type": "color", "$value": "{Semantic.theme.secondary.foreground}" }
      },
      "ghost": {
        "background": {
          "hover": { "$type": "color", "$value": "{Semantic.theme.accent.DEFAULT}" }
        },
        "foreground": {
          "default": { "$type": "color", "$value": "{Semantic.theme.primary.DEFAULT}" },
          "hover": { "$type": "color", "$value": "{Semantic.theme.accent.foreground}" }
        }
      },
      "destructive": {
        "background": {
          "default": { "$type": "color", "$value": "{Semantic.theme.destructive.DEFAULT}" },
          "hover": { 
            "$type": "color", 
            "$value": {
              "light": "{Primitives.color.red.900}",
              "dark": "{Primitives.color.red.500}"
            }
          }
        },
        "foreground": { "$type": "color", "$value": "{Semantic.theme.destructive.foreground}" }
      },
      "outline": {
        "border": { "$type": "color", "$value": "{Semantic.theme.input}" }
      }
    }
  }
}