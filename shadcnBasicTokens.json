{
  "Primitives": {
    "color": {
      "white": { "$value": "#ffffff", "$type": "color" },
      "black": { "$value": "#000000", "$type": "color" },
      "slate": {
        "50": { "$value": "#f8fafc", "$type": "color" },
        "100": { "$value": "#f1f5f9", "$type": "color" },
        "200": { "$value": "#e2e8f0", "$type": "color" },
        "300": { "$value": "#cbd5e1", "$type": "color" },
        "400": { "$value": "#94a3b8", "$type": "color" },
        "500": { "$value": "#64748b", "$type": "color" },
        "600": { "$value": "#475569", "$type": "color" },
        "700": { "$value": "#334155", "$type": "color" },
        "800": { "$value": "#1e293b", "$type": "color" },
        "900": { "$value": "#0f172a", "$type": "color" },
        "950": { "$value": "#020617", "$type": "color" }
      },
      "red": {
        "50": { "$value": "#fef2f2", "$type": "color" },
        "500": { "$value": "#ef4444", "$type": "color" },
        "900": { "$value": "#7f1d1d", "$type": "color" }
      }
    },
    "spacing": {
      "0": { "$value": "0px", "$type": "dimension" },
      "1": { "$value": "4px", "$type": "dimension" },
      "2": { "$value": "8px", "$type": "dimension" },
      "3": { "$value": "12px", "$type": "dimension" },
      "4": { "$value": "16px", "$type": "dimension" },
      "6": { "$value": "24px", "$type": "dimension" },
      "8": { "$value": "32px", "$type": "dimension" },
      "12": { "$value": "48px", "$type": "dimension" }
    },
    "radius": {
      "none": { "$value": "0px", "$type": "dimension" },
      "sm": { "$value": "4px", "$type": "dimension" },
      "md": { "$value": "6px", "$type": "dimension" },
      "lg": { "$value": "8px", "$type": "dimension" },
      "full": { "$value": "9999px", "$type": "dimension" }
    }
  },
  "Semantic": {
    "theme": {
      "background": {
        "$type": "color",
        "$value": {
          "light": "{Primitives.color.white}",
          "dark": "{Primitives.color.slate.950}"
        }
      },
      "foreground": {
        "$type": "color",
        "$value": {
          "light": "{Primitives.color.slate.950}",
          "dark": "{Primitives.color.slate.50}"
        }
      },
      "card": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.white}",
            "dark": "{Primitives.color.slate.950}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.950}",
            "dark": "{Primitives.color.slate.50}"
          }
        }
      },
      "popover": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.white}",
            "dark": "{Primitives.color.slate.950}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.950}",
            "dark": "{Primitives.color.slate.50}"
          }
        }
      },
      "primary": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.900}",
            "dark": "{Primitives.color.slate.50}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.50}",
            "dark": "{Primitives.color.slate.900}"
          }
        }
      },
      "secondary": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.100}",
            "dark": "{Primitives.color.slate.800}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.900}",
            "dark": "{Primitives.color.slate.50}"
          }
        }
      },
      "muted": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.100}",
            "dark": "{Primitives.color.slate.800}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.500}",
            "dark": "{Primitives.color.slate.400}"
          }
        }
      },
      "accent": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.100}",
            "dark": "{Primitives.color.slate.800}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.900}",
            "dark": "{Primitives.color.slate.50}"
          }
        }
      },
      "destructive": {
        "DEFAULT": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.red.500}",
            "dark": "{Primitives.color.red.900}"
          }
        },
        "foreground": {
          "$type": "color",
          "$value": {
            "light": "{Primitives.color.slate.50}",
            "dark": "{Primitives.color.slate.50}"
          }
        }
      },
      "border": {
        "$type": "color",
        "$value": {
          "light": "{Primitives.color.slate.200}",
          "dark": "{Primitives.color.slate.800}"
        }
      },
      "input": {
        "$type": "color",
        "$value": {
          "light": "{Primitives.color.slate.200}",
          "dark": "{Primitives.color.slate.800}"
        }
      },
      "ring": {
        "$type": "color",
        "$value": {
          "light": "{Primitives.color.slate.950}",
          "dark": "{Primitives.color.slate.300}"
        }
      },
      "radius": {
        "$type": "dimension",
        "$value": "{Primitives.radius.md}",
        "$description": "Radius applies globally to both light and dark modes"
      }
    }
  }
}